{
  "name": "ancient-kingdoms-mods",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "dev": "pnpm --filter website dev",
    "build": "pnpm --filter website build",
    "preview": "pnpm --filter website preview",
    "cf-deploy": "pnpm --filter website cf-deploy",
    "lint": "pnpm lint:ts && pnpm lint:py",
    "lint:ts": "pnpm --filter website lint",
    "lint:py": "cd build-pipeline && uv run ruff check .",
    "lint:fix": "pnpm lint:fix:ts && pnpm lint:fix:py",
    "lint:fix:ts": "pnpm --filter website lint:fix",
    "lint:fix:py": "cd build-pipeline && uv run ruff check --fix .",
    "format": "pnpm format:ts && pnpm format:py",
    "format:ts": "pnpm --filter website format",
    "format:py": "cd build-pipeline && uv run ruff format .",
    "check": "pnpm check:ts && pnpm check:py && pnpm check:knip",
    "check:ts": "pnpm --filter website check",
    "check:py": "cd build-pipeline && uv run mypy . && uv run vulture src/ --min-confidence 80",
    "check:knip": "knip"
  },
  "packageManager": "pnpm@10.22.0",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9"
  }
}
