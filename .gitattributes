# Git attributes for consistent handling across platforms

# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.cs text diff=csharp
*.csproj text
*.props text
*.md text
*.sh text eol=lf

# Windows-specific files (keep CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.dll binary
*.pdb binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
