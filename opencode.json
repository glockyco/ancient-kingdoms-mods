{
  "$schema": "https://opencode.ai/config.json",

  "compaction": {
    "auto": true,
    "prune": true
  },

  "share": "manual",

  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "allow",
      "git push*": "ask",
      "git commit*": "ask",
      "rm -r*": "ask"
    },
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "external_directory": "ask"
  },

  "watcher": {
    "ignore": [
      "exported-data/**",
      "server-scripts/**",
      "server-scripts-*/**",
      ".steam-download/**",
      "build/**",
      "**/node_modules/**",
      "**/.venv/**",
      "**/__pycache__/**",
      "**/bin/**",
      "**/obj/**",
      ".svelte-kit/**",
      ".vs/**",
      ".idea/**",
      ".vscode/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**"
    ]
  }
}
